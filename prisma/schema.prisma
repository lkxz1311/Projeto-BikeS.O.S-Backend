generator client {
  provider = "prisma-client"
  output          = "./generated/prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  email     String   @unique
  nome      String
  senha     String
  telefone  String
  tipo      String   @default("cliente")
  updatedAt DateTime @updatedAt
  pedidos   Pedido[]
}

model Pedido {
  id          String   @id @default(uuid())
  codigo      String
  tipo        String
  telefone    String
  problema    String
  bike        String
  localizacao String
  pagamento   String
  status      String   @default("Aguardando técnico aceitar")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}